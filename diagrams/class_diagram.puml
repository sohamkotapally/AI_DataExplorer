@startuml AI_DataExplorer_Class_Diagram

!theme cyborg
title AI Data Explorer - Class Diagram

scale 0.75

skinparam backgroundColor #1a1a2e
skinparam defaultFontColor #e0e0e0
skinparam defaultFontName Inter
skinparam defaultFontSize 10
skinparam roundcorner 8

skinparam class {
    BackgroundColor #2d2d44
    BorderColor #6c5ce7
    FontColor #ffffff
    HeaderBackgroundColor #3d3d5c
    AttributeFontColor #e0e0e0
    StereotypeFontColor #a29bfe
    ArrowColor #6c5ce7
    FontSize 10
}

skinparam package {
    BackgroundColor #16213e
    BorderColor #6c5ce7
    FontColor #a29bfe
}

skinparam arrow {
    Color #6c5ce7
    FontColor #a29bfe
    FontSize 9
}

skinparam pageMargin 5
skinparam dpi 96

package "Backend (FastAPI)" #16213e {

    class FastAPIApp <<Controller>> {
        + POST /upload(file)
        + POST /ask(question)
        + POST /clear-upload()
        + GET /upload-status()
    }

    class QueryRequest <<Pydantic>> {
        + question : str
    }

    class SQLDatabase <<LangChain>> {
        + run(sql) : str
    }

    class ChatOllama <<LangChain>> {
        + invoke(prompt) : AIMessage
    }

    class SQLQueryChain <<LangChain>> {
        + invoke(input) : str
    }

    FastAPIApp --> QueryRequest
    FastAPIApp --> SQLDatabase
    FastAPIApp --> ChatOllama
    FastAPIApp --> SQLQueryChain
}

package "Frontend (React)" #16213e {

    class App <<Component>> {
        - chats : Chat[]
        - uploadedFile : FileInfo
        - visualize : boolean
        + handleSend()
        + handleClearFile()
    }

    class Sidebar <<Component>> {
        + startNewChat()
        + deleteChat(id)
    }

    class ChatArea <<Component>> {
        + handleSend()
        + setVisualize(v)
    }

    class MessageBubble <<Component>>
    class EmptyState <<Component>>
    class FileUpload <<Component>>

    class DataVisualization <<Component>> {
        + renderChart()
        + switchChartType(type)
    }

    class ChartUtils <<Utility>> {
        + detectChartType() : string
        + transformForChart() : object[]
    }

    App *-- Sidebar
    App *-- ChatArea
    ChatArea *-- MessageBubble
    ChatArea *-- EmptyState
    EmptyState *-- FileUpload
    MessageBubble *-- DataVisualization
    DataVisualization ..> ChartUtils : uses
}

package "Data Models" #16213e {

    class Chat <<Model>> {
        + id : number
        + title : string
        + messages : Message[]
    }

    class Message <<Model>> {
        + role : string
        + content : string
        + tableData : TableData
    }

    class TableData <<Model>> {
        + columns : string[]
        + rows : string[][]
    }

    class FileInfo <<Model>> {
        + filename : string
        + rows : number
        + columns : number
    }

    Chat "1" *-- "0..*" Message
    Message "1" o-- "0..1" TableData
}

App ..> Chat : manages
App ..> FileInfo : tracks
FE ..> BE : HTTP (Axios)

@enduml
