@startuml AI_DataExplorer_System_Architecture

!theme cyborg
title AI Data Explorer — System Architecture

skinparam backgroundColor #1a1a2e
skinparam defaultFontColor #e0e0e0
skinparam defaultFontName Inter
skinparam roundcorner 12
skinparam nodesep 50
skinparam ranksep 40

skinparam component {
    BackgroundColor #2d2d44
    BorderColor #6c5ce7
    FontColor #ffffff
}

skinparam package {
    BackgroundColor #1e1e36
    BorderColor #a29bfe
    FontColor #dfe6e9
}

skinparam database {
    BackgroundColor #2d2d44
    BorderColor #00cec9
    FontColor #ffffff
}

skinparam cloud {
    BackgroundColor #2d2d44
    BorderColor #fd79a8
    FontColor #ffffff
}

skinparam arrow {
    Color #a29bfe
    Thickness 2
}

' ── CLIENT ──

package "Frontend — React SPA (Vite)" as FE {
    component "Sidebar\nChatArea\nEmptyState" as UIComps
    component "FileUpload\nMessageBubble\nDataVisualization" as UIComps2
    component "Recharts · Framer Motion\nAxios · Lucide Icons" as Libs
}

' ── SERVER ──

package "Backend — FastAPI (Python)" as BE {
    component "POST /ask\nPOST /upload\nPOST /clear-upload\nGET /upload-status" as Endpoints
    component "SQL Cleaner\nFile Parser\nLangChain" as Pipeline
}

' ── DATA ──

database "MySQL\n(Default DB)" as MySQL
database "SQLite\n(Uploaded File)" as SQLite
database "localStorage\n(Chat History)" as LS

' ── AI ──

cloud "Ollama\nLlama 3" as LLM

' ── CONNECTIONS ──

UIComps -[hidden]right- UIComps2
UIComps2 -[hidden]right- Libs

FE -down-> BE : HTTP API\n(JSON / multipart)
FE -down-> LS : Persist chats

Endpoints -right-> Pipeline
Pipeline -down-> MySQL : Default queries
Pipeline -down-> SQLite : Uploaded data queries
Pipeline -right-> LLM : NL → SQL\nResult → Summary

@enduml
