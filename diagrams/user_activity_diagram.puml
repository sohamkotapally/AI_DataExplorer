@startuml AI_DataExplorer_User_Activity_Diagram

!theme cyborg
title AI Data Explorer — User Activity Diagram

skinparam backgroundColor #1a1a2e
skinparam defaultFontColor #e0e0e0
skinparam defaultFontName Inter
skinparam roundcorner 10
skinparam ActivityFontSize 12

skinparam activity {
    BackgroundColor #2d2d44
    BorderColor #6c5ce7
    FontColor #ffffff
    BarColor #6c5ce7
    DiamondBackgroundColor #2d2d44
    DiamondBorderColor #a29bfe
    DiamondFontColor #ffffff
}

start

:Open App in Browser;
:View **Empty State** (Upload zone + Suggestions);

if (Upload own data?) then (yes)
    :Select / drag-drop file;
    if (Valid format?) then (yes)
        :Backend parses file → SQLite DB;
        :File badge shown in Sidebar;
    else (no)
        :Show error message;
    endif
else (no)
    :Use default MySQL database;
endif

repeat
    :Type question or click suggestion;
    :Backend: LLM → SQL → Execute → Summarize;

    if (Success?) then (yes)
        :Show answer + chart + SQL;
        if (Change chart type?) then (yes)
            :Switch visualization;
        endif
    else (no)
        :Show error card;
    endif
repeat while (Continue?) is (yes)

stop

@enduml
