@startuml AI_DataExplorer_UseCase_Diagram

!theme cyborg
title AI Data Explorer — Use-Case Diagram

scale 0.75

skinparam backgroundColor #1a1a2e
skinparam defaultFontColor #e0e0e0
skinparam defaultFontName Inter
skinparam defaultFontSize 11
skinparam roundcorner 8

skinparam usecase {
    BackgroundColor #2d2d44
    BorderColor #6c5ce7
    FontColor #ffffff
    FontSize 10
    ArrowColor #6c5ce7
    StereotypeFontColor #a29bfe
}

skinparam actor {
    BackgroundColor #6c5ce7
    BorderColor #6c5ce7
    FontColor #e0e0e0
    FontSize 10
}

skinparam rectangle {
    BackgroundColor #16213e
    BorderColor #6c5ce7
    FontColor #a29bfe
    StereotypeFontColor #a29bfe
    RoundCorner 12
}

skinparam package {
    BackgroundColor #16213e
    BorderColor #6c5ce7
    FontColor #a29bfe
}

skinparam arrow {
    Color #6c5ce7
    FontColor #a29bfe
    FontSize 9
}

skinparam note {
    BackgroundColor #2d2d44
    BorderColor #6c5ce7
    FontColor #e0e0e0
}

' ── Page size hint ──
skinparam pageMargin 5
skinparam dpi 96

' ── Actors ──
:User: as User

rectangle "AI Data Explorer" {

    ' ── File Management ──
    usecase "Upload Data File\n(CSV / XLSX)" as UC_Upload
    usecase "Remove Uploaded File" as UC_Clear
    usecase "Parse & Sanitize\nColumns" as UC_Parse
    usecase "Create Temp\nSQLite Database" as UC_TempDB

    ' ── Querying ──
    usecase "Ask Natural-Language\nQuestion" as UC_Ask
    usecase "Generate SQL\nfrom Question" as UC_GenSQL
    usecase "Execute SQL Query" as UC_ExecSQL
    usecase "Summarize Result\nin Natural Language" as UC_Summary

    ' ── Visualization ──
    usecase "Toggle Visualization\nMode" as UC_Toggle
    usecase "Auto-Detect\nChart Type" as UC_DetectChart
    usecase "Render Interactive\nChart" as UC_RenderChart
    usecase "View Data Table" as UC_Table

    ' ── User → Use-Cases ──
    User --> UC_Upload
    User --> UC_Clear
    User --> UC_Ask
    User --> UC_Toggle
    User --> UC_Table

    ' ── Include / Extend relationships ──
    UC_Upload ..> UC_Parse      : <<include>>
    UC_Parse  ..> UC_TempDB     : <<include>>

    UC_Ask    ..> UC_GenSQL     : <<include>>
    UC_GenSQL ..> UC_ExecSQL    : <<include>>
    UC_ExecSQL ..> UC_Summary   : <<include>>

    UC_Toggle  ..> UC_DetectChart : <<include>>
    UC_DetectChart ..> UC_RenderChart : <<include>>
}

' ── External Systems ──
:LLM\n(Ollama Llama3): as LLM  #2d2d44
:Database\n(MySQL / SQLite): as DB #2d2d44

LLM <-- UC_GenSQL
LLM <-- UC_Summary
DB  <-- UC_ExecSQL
DB  <-- UC_TempDB

@enduml
